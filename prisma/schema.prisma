generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Topic {
  id           String    @id @default(cuid())
  municipality String    @default("fujikawaguchiko")
  title        String
  summary      String
  rawText      String
  meetingDate  DateTime
  meetingName  String
  keywords     String[]
  sourceUrl    String?
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  opinions     Opinion[]
}

model Opinion {
  id        String   @id @default(cuid())
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id])
  stance    String
  userType  String
  content   String
  anonymous Boolean  @default(true)
  createdAt DateTime @default(now())
}
